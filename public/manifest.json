{
  "manifest_version": 3,
  "name": "Qubic Wallet",
  "description": "Qubic Wallet extension popup built with React and Vite.",
  "version": "0.1.0",
  "icons": {
    "16": "icons/light-16.png",
    "32": "icons/light-32.png",
    "48": "icons/light-48.png",
    "128": "icons/light-128.png"
  },
  "action": {
    "default_title": "Qubic Wallet",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/light-16.png",
      "32": "icons/light-32.png",
      "48": "icons/light-48.png",
      "128": "icons/light-128.png"
    }
  },
  "permissions": ["sidePanel", "windows", "storage"],
  "host_permissions": ["https://rpc.qubic.org/*", "http://*/*", "https://*/*"],
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["assets/content-script.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/inpage-provider.js"],
      "matches": ["http://*/*", "https://*/*"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; font-src 'self' data:; style-src 'self' 'unsafe-inline'; connect-src 'self' https://rpc.qubic.org"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}
